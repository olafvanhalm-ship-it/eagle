# Eagle Platform — Environment Configuration
# Copy this file to .env and adjust values for your environment.

# =============================================================================
# Database
# =============================================================================
# PostgreSQL (recommended for production and local development):
DATABASE_URL=postgresql://eagle_user:eagle_pass@localhost:5432/eagle_dev

# SQLite (alternative for quick testing — no PostgreSQL required):
# DATABASE_URL=sqlite:///eagle_review.db

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Paths (override only if not using default project structure)
# =============================================================================
# EAGLE_APP_ROOT=C:\Dev\eagle\Application
# EAGLE_ADAPTER_PATH=C:\Dev\eagle\Application\Adapters\Input adapters\M adapter

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
